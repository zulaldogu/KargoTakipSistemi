@model IEnumerable<KargoTakipSistemi.Models.DurumKaydi>

@{
    ViewData["Title"] = "Durum Kayıtları";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Durum Kayıtları</h1>
    <a asp-action="Create" class="btn btn-primary">Yeni Durum Kaydı Ekle</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Kargo Takip No</th>
            <th>Durum</th>
            <th>Açıklama</th>
            <th>Tarih</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    Henüz kayıtlı durum kaydı bulunmamaktadır.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Kargo?.TakipNo</td>
                    <td>@item.Durum</td>
                    <td>@item.Aciklama</td>
                    <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detay</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>