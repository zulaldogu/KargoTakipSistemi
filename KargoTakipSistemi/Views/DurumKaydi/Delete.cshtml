@model KargoTakipSistemi.Models.DurumKaydi

@{
    ViewData["Title"] = "Durum Kaydı Sil";
}

<h1>Durum Kaydı Sil</h1>

<div class="alert alert-danger mt-3">
    Bu durum kaydını silmek istediğinize emin misiniz?
</div>

<div class="card">
    <div class="card-header">
        <strong>@Model.Kargo?.TakipNo</strong> numaralı kargo durum kaydı
    </div>

    <div class="card-body">
        <p><strong>Kargo Takip No:</strong> @Model.Kargo?.TakipNo</p>
        <p><strong>Durum:</strong> @Model.Durum</p>
        <p><strong>Açıklama:</strong> @Model.Aciklama</p>
        <p><strong>Tarih:</strong> @Model.Tarih.ToString("dd.MM.yyyy HH:mm")</p>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
</form>