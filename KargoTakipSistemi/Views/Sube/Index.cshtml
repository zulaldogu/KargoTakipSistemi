@model IEnumerable<KargoTakipSistemi.Models.Sube>

@{
    ViewData["Title"] = "Şubeler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Şubeler</h1>
    <a asp-action="Create" class="btn btn-primary">Yeni Şube Ekle</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Şube Adı</th>
            <th>Şehir</th>
            <th>Adres</th>
            <th>Telefon</th>
            <th>Kargo Sayısı</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    Henüz kayıtlı şube bulunmamaktadır.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SubeAdi</td>
                    <td>@item.Sehir</td>
                    <td>@item.Adres</td>
                    <td>@item.Telefon</td>
                    <td>@(item.Kargolar?.Count ?? 0)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detay</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>